---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/siteConfig.js";

const pageTitle = `Política de Privacidade | ${siteConfig.siteName}`;
const pageDescription =
  "Saiba como a ATEB Soluções trata os dados compartilhados pelos visitantes do site.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main class="ateb-section">
    <section class="ateb-container">
      <div class="ateb-card grid gap-8 p-6 md:p-10">
        <div class="grid gap-4">
          <span class="ateb-kicker">Legal</span>
          <h1 class="ateb-section-title max-w-[12ch]">
            Política de Privacidade
          </h1>
          <p class="ateb-section-text max-w-[72ch]">
            Esta página explica de forma objetiva como a {siteConfig.businessName}
            trata as informações compartilhadas por visitantes e clientes em seus
            canais digitais.
          </p>
        </div>

        <div class="grid gap-6">
          <section class="grid gap-3">
            <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-ateb-dark">
              1. Dados que podem ser coletados
            </h2>
            <p class="ateb-section-text">
              Podemos receber nome, telefone, e-mail, empresa e outras
              informações enviadas voluntariamente em formulários, contatos por
              WhatsApp ou interações comerciais.
            </p>
          </section>

          <section class="grid gap-3">
            <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-ateb-dark">
              2. Finalidade do uso
            </h2>
            <p class="ateb-section-text">
              Os dados são utilizados para responder solicitações, apresentar
              serviços, conduzir atendimentos comerciais e melhorar a experiência
              de navegação e relacionamento com a empresa.
            </p>
          </section>

          <section class="grid gap-3">
            <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-ateb-dark">
              3. Compartilhamento
            </h2>
            <p class="ateb-section-text">
              A {siteConfig.businessName} não comercializa dados pessoais. O
              compartilhamento pode ocorrer apenas quando necessário para a
              operação do atendimento, cumprimento de obrigações legais ou uso de
              ferramentas técnicas de suporte ao site e ao relacionamento.
            </p>
          </section>

          <section class="grid gap-3">
            <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-ateb-dark">
              4. Direitos do titular
            </h2>
            <p class="ateb-section-text">
              O titular pode solicitar atualização, correção ou exclusão de dados
              pessoais, quando aplicável, pelos canais de contato informados neste
              site.
            </p>
          </section>

          <section class="grid gap-3">
            <h2 class="font-display text-2xl font-bold tracking-[-0.03em] text-ateb-dark">
              5. Contato
            </h2>
            <p class="ateb-section-text">
              Para assuntos relacionados à privacidade, entre em contato pelo
              e-mail {siteConfig.emails[0]} ou pelo telefone {siteConfig.phones[0]}.
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>
