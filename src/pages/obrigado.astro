---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/siteConfig.js";

const pageTitle = `Recebemos seu contato com sucesso | ${siteConfig.siteName}`;
const pageDescription =
  "Página de confirmação de contato da ATEB Soluções.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  robots="noindex, follow"
>
<main class="ateb-grid-pattern relative flex min-h-screen items-start justify-center overflow-hidden px-5 pb-16 pt-28 sm:px-6 sm:pb-20 sm:pt-32 md:px-8 md:pb-24 md:pt-36 lg:items-center lg:px-6 lg:py-16">
      <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_22%,rgba(179,209,51,0.18),transparent_24%),radial-gradient(circle_at_70%_30%,rgba(179,209,51,0.14),transparent_22%),radial-gradient(circle_at_86%_72%,rgba(77,72,55,0.08),transparent_20%)]"
      aria-hidden="true"
    >
    </div>

    <section class="ateb-container relative py-4 sm:py-6 md:py-8 lg:py-0">
      <div
        class="grid items-center gap-10 md:gap-12 lg:min-h-[calc(100vh-10rem)] lg:grid-cols-[1.02fr_0.98fr] lg:gap-14"
      >
        <div class="grid gap-6 text-center lg:text-center">

          <h1
            class="font-sora mx-auto max-w-[15ch] text-[clamp(2rem,5vw,4rem)] font-extrabold leading-[1.06] tracking-[-0.06em] text-ateb-dark lg:mx-0"
          >
            Recebemos seu contato com sucesso
          </h1>

          <p
            class="mx-auto max-w-[60ch] text-[clamp(1rem,2.2vw,1.16rem)] leading-[1.75] text-[rgba(77,72,55,0.84)] lg:mx-0"
          >
            Obrigado por entrar em contato com a ATEB Soluções. Sua mensagem foi
            enviada e nossa equipe irá retornar o mais breve possível.
          </p>

          <p
            class="mx-auto max-w-[60ch] text-[clamp(0.8rem,2.2vw,1.16rem)] leading-[1.75] text-[rgba(77,72,55,0.84)] lg:mx-0"
          >
            Se preferir agilizar o atendimento, você também pode falar conosco
            diretamente pelo WhatsApp.
          </p>

          <div
            class="flex w-full flex-wrap justify-center gap-4 pt-2 lg:justify-center"
          >
            <a
              href={siteConfig.thankYouWhatsAppUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="ateb-button-accent"
            >
              Falar no WhatsApp
            </a>
          </div>

           <p
          class="inline-flex items-center justify-center gap-2 text-sm font-semibold text-[rgba(77,72,55,0.72)] lg:justify-center"
        >
          <span aria-hidden="true"
            ><svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 1000 700"
              class="h-4 w-6 rounded-sm shadow-sm"
              aria-hidden="true"
            >
              <rect width="1000" height="700" fill="#009b3a"></rect>
              <polygon points="500,100 900,350 500,600 100,350" fill="#ffdf00"
              ></polygon>
              <circle cx="500" cy="350" r="140" fill="#002776"></circle>

              <path
                d="M360 330c40-25 90-40 140-40s100 15 140 40"
                fill="none"
                stroke="#fff"
                stroke-width="28"></path>
            </svg></span
          >
          Atendimento para empresas em todo o Brasil.
        </p>
        </div>

       
      </div>
    </section>
  </main>
</Layout>
