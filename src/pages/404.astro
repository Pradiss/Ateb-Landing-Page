---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config/siteConfig.js";

const pageTitle = `Página não encontrada | ${siteConfig.siteName}`;
const pageDescription =
  "A página que você tentou acessar não foi encontrada.";
---

<Layout title={pageTitle} description={pageDescription} robots="noindex, follow">
  <main class="ateb-section">
    <section class="ateb-container">
      <div class="ateb-card grid gap-8 overflow-hidden p-6 md:p-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
        <div class="grid gap-5">
          <span class="ateb-kicker">Erro 404</span>

          <h1 class="ateb-section-title max-w-[10ch]">
            Página não encontrada
          </h1>

          <p class="ateb-section-text max-w-[58ch]">
            O link acessado pode estar incorreto, desatualizado ou a página pode
            ter sido movida. Você pode voltar para a landing principal e seguir
            a navegação normalmente.
          </p>

          <div class="flex flex-wrap gap-4">
            <a href={siteConfig.primaryRoute} class="ateb-button-primary">
              Ir para a página principal
            </a>
            <a
              href={siteConfig.whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="ateb-button-secondary"
            >
              Falar pelo WhatsApp
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="rounded-[1.5rem] border border-[rgba(77,72,55,0.08)] bg-[linear-gradient(135deg,rgba(179,209,51,0.16),rgba(255,255,255,0.72))] p-6 md:p-8">
            <p class="font-display text-[clamp(4rem,10vw,7rem)] font-bold leading-none tracking-[-0.08em] text-ateb-dark">
              404
            </p>
            <p class="mt-4 text-sm leading-7 text-[rgba(77,72,55,0.84)]">
              Se quiser, você também pode usar o menu principal ou acessar uma
              das páginas legais no rodapé.
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
