---
import { siteConfig } from "../config/siteConfig.js";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0; url=${siteConfig.primaryRoute}`} />
    <meta name="robots" content="noindex, follow" />
    <title>Redirecionando...</title>
    <script define:vars={{ primaryRoute: siteConfig.primaryRoute }}>
      window.location.replace(primaryRoute);
    </script>
  </head>
  <body>
    <p>
      Redirecionando para
      <a href={siteConfig.primaryRoute}>{siteConfig.primaryRoute}</a>.
    </p>
  </body>
</html>
