---
import { buildWhatsAppUrl } from "../../config/siteConfig.js";

const ctaUrl = buildWhatsAppUrl(
  "Ola, vim pela pagina da ATEB Solucoes e quero solicitar um diagnostico pelo WhatsApp."
);
---

<section class="relative overflow-hidden py-[clamp(4rem,6vw,6rem)]">
  <div class="ateb-container">
    <div class="relative overflow-hidden rounded-[2.2rem] bg-[linear-gradient(135deg,#4d4837_0%,#1d120a_100%)] px-6 py-10 text-white shadow-[0_28px_70px_rgba(29,18,10,0.20)] md:px-8 lg:px-10">
      
      <div
        class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-ateb-lime/20 blur-3xl"
        aria-hidden="true"
      ></div>

      <div
        class="pointer-events-none absolute -bottom-24 -left-20 h-72 w-72 rounded-full bg-white/10 blur-3xl"
        aria-hidden="true"
      ></div>

      <div class="relative grid gap-8 lg:grid-cols-[1fr_360px] lg:items-center">
        <div class="grid max-w-[760px] gap-4">
          <span class="inline-flex w-fit rounded-full border border-white/10 bg-white/10 px-3 py-1.5 text-xs font-extrabold uppercase tracking-[0.14em] text-white">
            CTA intermediário
          </span>

          <h2 class="font-sora text-[clamp(2rem,4vw,3.2rem)] font-extrabold leading-[1.06] tracking-[-0.06em] text-white">
            Quer entender onde sua operação pode melhorar?
          </h2>

          <p class="max-w-[62ch] text-[1.03rem] leading-[1.75] text-white/76">
            Fale com a ATEB Soluções e solicite uma avaliação inicial do seu
            cenário. Vamos entender sua realidade e indicar o melhor caminho para
            organizar, automatizar e integrar seus processos.
          </p>

          <div class="flex flex-wrap gap-4 pt-2">
            <a
              href={ctaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-[3.35rem] items-center justify-center rounded-full bg-ateb-lime px-7 py-3.5 text-sm font-extrabold text-ateb-dark shadow-[0_18px_35px_rgba(179,209,51,0.25)] transition hover:-translate-y-1 hover:shadow-[0_24px_45px_rgba(179,209,51,0.34)]"
            >
              Solicitar diagnóstico pelo WhatsApp
            </a>
          </div>

          <p class="text-xs font-semibold leading-5 text-white/55">
            Atendimento consultivo para empresas em todo o Brasil.
          </p>
        </div>

        <div class="relative order lg:block">
          <div
            class="pointer-events-none absolute inset-x-8 bottom-3 h-8 rounded-full bg-black/30 blur-2xl"
            aria-hidden="true"
          ></div>

          <img
            src="/images/home-about.webp"
            alt="Equipe em reunião avaliando indicadores"
            loading="lazy"
            class="relative ml-auto h-[360px] w-full rounded-[1.6rem] object-cover shadow-[0_24px_55px_rgba(0,0,0,0.28)]"
          />
        </div>
      </div>

    </div>
  </div>
</section>