---
const cases = [
  {
    company: "Perlima Metais Perfurados",
    logo: "/Logo/perlima.png",
    title: "Fluig integrado ao TOTVS RM para automatizar processos internos",
    description:
      "A Perlima utilizou o Fluig integrado ao TOTVS RM para criar fluxos personalizados, reduzir tarefas manuais e dar mais autonomia às áreas da empresa.",
    result:
      "Mais organização nos processos, menos dependência de controles manuais e maior integração entre operação e sistema.",
  },
  {
    company: "Jofege Pavimentação e Construção",
    logo: "/Logo/jofege_logo.svg",
    title: "Revitalização do TOTVS RM para mais controle operacional",
    description:
      "Com a revitalização do TOTVS RM, os módulos de compras, faturamento, estoque, fiscal e contábil ganharam mais organização e controle.",
    result:
      "Rotinas mais estruturadas, informações mais confiáveis e melhor aproveitamento do ERP.",
  },
  {
    company: "Auto Pecas Motoristas",
    logo: "/Logo/motorista_logo.webp",
    title: "Implantação Sankhya com integração às vendas online",
    description:
      "Com a nova implantação do Sankhya, a empresa melhorou desempenho e usabilidade, além de integrar vendas online com Mercado Livre e Amazon.",
    result:
      "Operação mais conectada, melhor experiência de uso e integração entre ERP e canais digitais.",
  },
  {
    company: "Soleteto Empreendimentos",
    logo: "/Logo/Soleteto.png",
    title: "TOTVS RM integrado a IA via WhatsApp",
    description:
      "Com TOTVS RM integrado à IA via WhatsApp, a geração de boletos financeiros ficou mais ágil, automatizada e conectada à rotina do cliente.",
    result:
      "Mais velocidade no atendimento financeiro, automação de solicitações e redução de etapas manuais.",
  },
];
---

<section class="ateb-section" id="cases">
  <div class="ateb-container grid gap-8">
    <div class="mx-auto grid max-w-[760px] gap-4 text-center">
      <h2 class="ateb-section-title">
        Empresas que já evoluíram processos com projetos conduzidos pela ATEB
      </h2>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {cases.map((item) => (
        <article class="ateb-card grid gap-5 p-6">
          <div class="flex items-center gap-4">
            <div class="flex h-16 w-16 shrink-0 items-center justify-center rounded-[1.1rem] p-1 border border-[rgba(77,72,55,0.1)] bg-white shadow-[0_12px_26px_rgba(29,18,10,0.06)]">
              <img
                src={item.logo}
                alt={`Logo ${item.company}`}
                loading="lazy"
                class="max-h-10 w-auto object-contain"
              />
            </div>

            <div class="grid gap-1">
              <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-ateb-earth/65">
                {item.company}
              </p>

              <h3 class="font-sora text-[1.18rem] font-bold tracking-[-0.04em] text-ateb-dark">
                {item.title}
              </h3>
            </div>
          </div>

          <p class="text-sm leading-7 text-[rgba(77,72,55,0.8)]">
            {item.description}
          </p>

          <div class="rounded-[1.15rem] border border-[rgba(77,72,55,0.08)] bg-[rgba(247,244,236,0.7)] px-4 py-4">
            <p class="text-xs font-extrabold uppercase tracking-[0.16em] text-ateb-earth/70">
              Resultado percebido
            </p>

            <p class="mt-2 text-sm leading-7 text-[rgba(77,72,55,0.82)]">
              {item.result}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
