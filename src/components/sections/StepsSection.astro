---
const contactSectionUrl = "#contato";

const steps = [
  {
    title: "Diagnostico do cenario atual",
    text: "Entendemos os sistemas utilizados, os processos existentes, as dores da operacao e os principais gargalos.",
  },
  {
    title: "Analise tecnica e funcional",
    text: "Avaliamos como o ERP esta sendo usado, quais processos precisam ser ajustados e onde ha oportunidades de automacao ou integracao.",
  },
  {
    title: "Proposta de melhoria",
    text: "Definimos um plano de atuacao com prioridades, frentes de trabalho e caminhos para gerar mais eficiencia.",
  },
  {
    title: "Execucao consultiva",
    text: "Acompanhamos a implementacao das melhorias, parametrizacoes, integracoes, automacoes ou ajustes necessarios.",
  },
];
---

<section class="py-[clamp(4rem,6vw,6rem)]">
  <div class="ateb-container">
    <div
      class="mx-auto mb-9 grid max-w-[760px] justify-items-center gap-4 text-center"
    >
      <h2
        class="font-sora text-[clamp(1.65rem,2.65vw,2.55rem)] font-bold leading-[1.12] tracking-[-0.04em] text-ateb-dark"
      >
        Como a ATEB conduz o projeto
      </h2>
    </div>

    <ol class="grid list-none gap-5 p-0 md:grid-cols-2 xl:grid-cols-4">
      {
        steps.map((item, index) => (
          <li class="relative overflow-hidden rounded-[1.5rem] border border-[rgba(77,72,55,0.14)] bg-white/90 p-7 shadow-[0_24px_60px_rgba(29,18,10,0.08)] backdrop-blur-xl">
            <div class="mb-6 inline-flex min-h-[3.4rem] min-w-[3.4rem] items-center justify-center rounded-[1.1rem] border border-[rgba(77,72,55,0.16)] bg-[linear-gradient(135deg,rgba(179,209,51,0.30),rgba(77,72,55,0.16))] font-sora text-base font-bold tracking-[-0.04em] text-ateb-dark shadow-[0_14px_28px_rgba(29,18,10,0.12),inset_0_1px_0_rgba(255,255,255,0.35)]">
              {String(index + 1).padStart(2, "0")}
            </div>

            <h3 class="font-sora text-[clamp(1.08rem,1.55vw,1.35rem)] font-bold leading-[1.12] tracking-[-0.03em] text-ateb-dark">
              {item.title}
            </h3>

            <p class="mt-3 text-[1rem] leading-[1.65] text-[rgba(77,72,55,0.84)]">
              {item.text}
            </p>

            <span class="absolute inset-x-7 bottom-0 h-1 rounded-full bg-[linear-gradient(90deg,#b3d133,#4d4837)]" />
          </li>
        ))
      }
    </ol>

    
  </div>
</section>
