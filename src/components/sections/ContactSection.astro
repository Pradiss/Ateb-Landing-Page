---
import { siteConfig } from "../../config/siteConfig.js";

const contactEmail = siteConfig.emails[0];
const thankYouUrl = siteConfig.thankYouRoute;
---

<section class="ateb-section pb-20" id="contato">
  <div
    class="ateb-container grid items-stretch gap-6 lg:grid-cols-[0.9fr_1.1fr]"
  >
    <div class="relative overflow-hidden rounded-[2rem] p-7 lg:p-8">
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full"
        aria-hidden="true"
      >
      </div>

      <div class="relative flex min-h-full items-center justify-center overflow-hidden rounded-[2rem] p-7 text-center lg:p-8 lg:text-left">
        <div class="relative grid max-w-[520px] gap-4 lg:mx-0">
          <h2 class="font-sora text-[clamp(2rem,4vw,3.15rem)] font-extrabold leading-[1.06] tracking-[-0.06em] text-ateb-dark">
            Vamos avaliar o cenário da sua empresa?
          </h2>

          <p class="text-[1rem] leading-7 text-[rgba(77,72,55,0.84)]">
            Preencha o formulário para entender como a ATEB pode ajudar sua
            operação a ganhar mais eficiência, controle e performance.
          </p>
        </div>
      </div>
    </div>

    <div
      class="relative overflow-hidden rounded-[2rem] border border-[rgba(77,72,55,0.12)] bg-white/95 p-6 shadow-[0_24px_60px_rgba(29,18,10,0.08)] backdrop-blur-xl lg:p-7"
    >
      <div
        class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-ateb-lime/15 blur-3xl"
        aria-hidden="true"
      >
      </div>

      <div class="relative mb-6 grid gap-2">
        <h3
          class="font-sora text-[1.55rem] font-extrabold tracking-[-0.05em] text-ateb-dark"
        >
          Conte sobre sua operação
        </h3>

        <p class="text-sm leading-6 text-[rgba(77,72,55,0.72)]">
          Envie seus dados e a mensagem será organizada automaticamente para o
          e-mail da ATEB: {contactEmail}.
        </p>
      </div>

      <form class="relative grid gap-4" data-email-form>
        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="text-sm font-bold text-ateb-earth">Nome</span>
            <input
              class="ateb-input"
              name="nome"
              type="text"
              placeholder="Seu nome"
              required
            />
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-bold text-ateb-earth">Empresa</span>
            <input
              class="ateb-input"
              name="empresa"
              type="text"
              placeholder="Nome da empresa"
              required
            />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="text-sm font-bold text-ateb-earth">
              Telefone / WhatsApp
            </span>
            <input
              class="ateb-input"
              name="telefone"
              type="tel"
              placeholder="(00) 00000-0000"
              required
            />
          </label>

          <label class="grid gap-2">
            <span class="text-sm font-bold text-ateb-earth">E-mail</span>
            <input
              class="ateb-input"
              name="email"
              type="email"
              placeholder="voce@empresa.com"
              required
            />
          </label>
        </div>

        <label class="grid gap-2">
          <span class="text-sm font-bold text-ateb-earth">
            Principal necessidade
          </span>
          <select class="ateb-input" name="necessidade" required>
            <option value="">Selecione</option>
            <option>TOTVS RM</option>
            <option>TOTVS Protheus</option>
            <option>TOTVS Fluig</option>
            <option>Sankhya</option>
            <option>Integração entre sistemas</option>
            <option>Automação de processos</option>
            <option>Outro</option>
          </select>
        </label>

        <label class="grid gap-2">
          <span class="text-sm font-bold text-ateb-earth">Mensagem</span>
          <textarea
            class="ateb-textarea min-h-[140px]"
            name="mensagem"
            placeholder="Conte um pouco sobre o cenário atual, dores ou objetivos da sua operação."
          ></textarea>
        </label>

        <div class="flex flex-wrap gap-4 pt-2">
          <button type="submit" class="ateb-button-primary">
            Solicitar diagnóstico
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ contactEmail, thankYouUrl }}>
  const form = document.querySelector("[data-email-form]");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const formData = new FormData(form);
    const fields = [
      ["Nome", formData.get("nome")],
      ["Empresa", formData.get("empresa")],
      ["Telefone / WhatsApp", formData.get("telefone")],
      ["E-mail", formData.get("email")],
      ["Principal necessidade", formData.get("necessidade")],
      ["Mensagem", formData.get("mensagem")],
    ];

    const message = [
      "Ola, vim pela landing page da ATEB Solucoes e gostaria de solicitar um diagnostico.",
      "",
      ...fields
        .filter(([, value]) => String(value ?? "").trim().length > 0)
        .map(([label, value]) => `${label}: ${String(value).trim()}`),
    ].join("\n");

    const company = String(formData.get("empresa") ?? "").trim();
    const subject = company
      ? `Solicitacao de diagnostico - ${company}`
      : "Solicitacao de diagnostico - Landing page ATEB";

    const mailtoLink = document.createElement("a");
    mailtoLink.href = `mailto:${contactEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(message)}`;
    mailtoLink.style.display = "none";

    document.body.appendChild(mailtoLink);
    mailtoLink.click();
    mailtoLink.remove();

    window.setTimeout(() => {
      window.location.assign(thankYouUrl);
    }, 250);
  });
</script>
